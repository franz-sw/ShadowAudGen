# ElevenLabs API Key (required for generating answer audios)
# Get your API key from: https://elevenlabs.io/app/settings/api-key
ELEVENLABS_API_KEY="sk_example_00000000000000000000000000000000"

# XAI API Key (optional - used if you want German translations in exports)
# Get your API key from: https://console.x.ai/
XAI_API_KEY=""

# Castopod Configuration (optional - for publishing episodes)
# CASTOPOD_HOST="https://your-castopod-instance.com"
# CASTOPOD_PODCAST_ID=""
# CASTOPOD_USER_ID=""
# CASTOPOD_AUTH_USERNAME=""
# CASTOPOD_AUTH_PASSWORD=""

# Base URL for shadowing sources (optional)
# SHADOWING_SOURCES_BASE_URL="https://your-storage.com/shadowing"